{
  "name": "notion-blog",
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "prebuild": "npx tsx scripts/copy-blog-assets.ts",
    "build": "next build && npx tsx ./src/lib/build-rss.ts && npx tsx ./src/lib/build-sitemap.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "og:generate": "npx tsx scripts/generate-og.ts",
    "format": "prettier --write \"**/*.{js,jsx,json,ts,tsx,md,mdx,css,html,yml,yaml,scss,sass}\" --ignore-path .gitignore",
    "lint-staged": "lint-staged"
  },
  "pre-commit": "lint-staged",
  "dependencies": {
    "gray-matter": "^4.0.3",
    "next": "^14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-prism-plus": "^2.0.2",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitest/ui": "^4.1.5",
    "lint-staged": "10.5.4",
    "pre-commit": "1.2.2",
    "prettier": "2.2.1",
    "puppeteer": "^24.42.0",
    "tsx": "^4.21.0",
    "typescript": "5.3.3",
    "vitest": "^4.1.5"
  }
}
